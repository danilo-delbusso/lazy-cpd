# Database (PostgreSQL)
# Local dev: matches docker-compose.yml defaults
DATABASE_URL=postgresql://cpd:cpd_dev_password@localhost:5432/cpd_portal

# Authentication
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-in-production

# Admin password for the /admin panel (min 16 characters in production)
# Generate with: openssl rand -base64 32
ADMIN_PASSWORD=change-me-in-production

# AI Content Generation (optional - feature disabled if not set)
ANTHROPIC_API_KEY=

# MCP Server Authentication (required for Claude Code integration)
# Generate with: openssl rand -hex 32
CPD_MCP_TOKEN=

# Seed mode: "ci" for synthetic test data, "production" for real data
SEED_MODE=ci

# Site owner name (shown in header and page titles)
NEXT_PUBLIC_SITE_OWNER=Your Name

# Public site links (shown in header)
NEXT_PUBLIC_GITHUB_URL=https://github.com/your-username
NEXT_PUBLIC_LINKEDIN_URL=
