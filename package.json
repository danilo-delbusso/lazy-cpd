{
	"name": "cpd-portal",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:unit": "vitest run --coverage",
		"test:integration": "vitest run --config vitest.integration.config.ts --coverage",
		"test:coverage": "bun run test:unit && bun run test:integration && lcov-result-merger 'coverage/lcov.info' 'coverage-integration/lcov.info' -o coverage/lcov.info",
		"e2e": "playwright test",
		"e2e:ui": "playwright test --ui",
		"e2e:visual": "playwright test --grep @visual",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:seed": "bun run drizzle/seed/seed.ts",
		"db:studio": "drizzle-kit studio"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.82.0",
		"@modelcontextprotocol/server": "2.0.0-alpha.2",
		"@paralleldrive/cuid2": "^3.3.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tanstack/react-query": "^5.96.1",
		"@uiw/react-md-editor": "^4.1.0",
		"drizzle-orm": "^0.45.2",
		"jose": "^6.2.2",
		"motion": "^12.23.12",
		"next": "16.2.2",
		"postgres": "^3.4.8",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-markdown": "^10.1.0",
		"react-plock": "^3.6.1",
		"rehype-sanitize": "^6.0.0",
		"remark-gfm": "^4.0.1",
		"server-only": "^0.0.1",
		"sonner": "^2.0.7",
		"spring-animator": "^2.0.1",
		"zod": "^4.3.6",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@playwright/test": "^1.59.1",
		"@tailwindcss/postcss": "^4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "^4.1.4",
		"drizzle-kit": "^0.31.10",
		"jsdom": "^29.0.1",
		"lcov-result-merger": "^5.0.1",
		"shadcn": "^4.1.2",
		"tailwindcss": "^4",
		"typescript": "^5",
		"vitest": "^4.1.2"
	},
	"engines": {
		"bun": ">=1.3.0"
	},
	"ignoreScripts": [
		"unrs-resolver"
	],
	"trustedDependencies": [
		"esbuild",
		"sharp",
		"unrs-resolver"
	]
}
